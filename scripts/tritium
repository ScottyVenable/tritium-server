#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TRITIUM_HOME="${TRITIUM_HOME:-$HOME/.tritium-os}"
REPO_ROOT_FILE="$TRITIUM_HOME/state/repo-root"

REPO_ROOT="${TRITIUM_REPO_ROOT:-}"
if [ -f "$DEFAULT_REPO_ROOT/runtime/cli/tritium.js" ]; then
    REPO_ROOT="$DEFAULT_REPO_ROOT"
elif [ -z "$REPO_ROOT" ] && [ -f "$REPO_ROOT_FILE" ]; then
    REPO_ROOT="$(head -n 1 "$REPO_ROOT_FILE")"
fi

if [ ! -f "${REPO_ROOT:-}/runtime/cli/tritium.js" ]; then
    echo "error: unable to locate Tritium repo root" >&2
    echo "re-run bash scripts/install.sh from a Tritium checkout or set TRITIUM_REPO_ROOT" >&2
    exit 1
fi

exec node "$REPO_ROOT/runtime/cli/tritium.js" "$@"
